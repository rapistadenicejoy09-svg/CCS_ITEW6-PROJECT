# Vercel (single deployment): leave empty — the browser calls /api on the same origin.
# Only set if the API is hosted elsewhere:
# VITE_API_BASE=https://your-api.example.com

# Required on Vercel for the serverless API + local `npm run server`:
MONGODB_URI=mongodb+srv://user:pass@cluster.example.mongodb.net/mydb?retryWrites=true&w=majority
# If the URI has no database path, set the name here:
# MONGODB_DB=ccs
